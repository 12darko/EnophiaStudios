rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Site content: everyone can read, only signed-in team members can write.
    match /site/content {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Admin-only secrets (e.g. Gemini API key). Public can NEVER read this;
    // only signed-in team members can read or write it.
    match /site/secrets {
      allow read, write: if request.auth != null;
    }
    // Everything else is locked down.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
